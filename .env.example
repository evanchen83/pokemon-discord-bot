DISCORD_BOT_TOKEN=your_discord_bot_token

# Optional command sync during startup
DISCORD_GUILD_ID=
DISCORD_SYNC_COMMANDS=false

# watsonx Orchestrate
WO_INSTANCE=https://your-orchestrate-instance
WO_API_KEY=your_orchestrate_api_key
WO_AGENT_NAME=pokemon_tcg_agent
WO_ENV=local

# Optional bot runtime override (use this when bot should talk to a different
# instance than CLI/import, e.g. local server while WO_INSTANCE points to cloud)
WO_RUNTIME_INSTANCE=
WO_RUNTIME_API_KEY=
WO_LOCAL_USERNAME=wxo.archer@ibm.com
WO_LOCAL_PASSWORD=watsonx

# Persistence
PACK_PG_DSN=postgresql://pokemon:pokemon@postgres:5432/pokemon_bot
THREAD_PG_DSN=postgresql://pokemon:pokemon@postgres:5432/pokemon_bot

# Sharding
DISCORD_SHARD_COUNT=2
DISCORD_SHARD_IDS=0
DISCORD_SYNC_LEADER=true

# Limits
THREAD_TTL_MINUTES=10
CATCH_DAILY_LIMIT=25

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9108
